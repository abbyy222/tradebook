// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PaymentType {
  CASH
  TRANSFER
  DEBT
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum DebtStatus {
  ACTIVE
  PARTIAL
  CLEARED
}

enum Language {
  EN
  PIDGIN
  IGBO
  YORUBA
  HAUSA
}

enum ExpenseCategory {
  RESTOCK
  TRANSPORT
  MARKET_FEES
  PACKAGING
  EQUIPMENT
  FOOD
  RENT
  ELECTRICITY
  WATER
  SALARY
  LEVY
  REPAIRS
  UTILITIES
  OTHER
}

enum ExpenseType {
  ONE_TIME
  RECURRING
}

enum ExpenseFrequency {
  DAILY
  MONTHLY
  YEARLY
}

model Trader {
  id           String    @id @default(uuid())
  phoneNumber  String    @unique @map("phone_number")
  name         String
  pinHash      String    @map("pin_hash")
  language     Language  @default(EN)
  businessName String?   @map("business_name")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  sales        Sale[]
  expenses     Expense[]
  stockItems   StockItem[]
  debtors      Debtor[]

  @@index([phoneNumber])
  @@map("traders")
}

model Sale {
  id          String      @id @default(uuid())
  traderId    String      @map("trader_id")
  debtorId    String?     @map("debtor_id")
  stockItemId String?     @map("stock_item_id")
  itemName    String      @map("item_name")
  quantity    Int         @default(1)
  unitPrice   Decimal     @db.Decimal(12, 2) @map("unit_price")
  amount      Decimal     @db.Decimal(12, 2)
  paymentType PaymentType @map("payment_type")
  syncStatus  SyncStatus  @default(PENDING) @map("sync_status")
  soldAt      DateTime    @map("sold_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  trader      Trader      @relation(fields: [traderId], references: [id], onDelete: Cascade)
  debtor      Debtor?     @relation(fields: [debtorId], references: [id])
  stockItem   StockItem?  @relation(fields: [stockItemId], references: [id])

  @@index([traderId])
  @@index([soldAt])
  @@index([stockItemId])
  @@index([traderId, soldAt])
  @@map("sales")
}

model Expense {
  id          String            @id @default(uuid())
  traderId    String            @map("trader_id")
  description String
  amount      Decimal           @db.Decimal(12, 2)
  category    ExpenseCategory
  expenseType ExpenseType       @default(ONE_TIME) @map("expense_type")
  frequency   ExpenseFrequency?
  note        String?
  syncStatus  SyncStatus        @default(PENDING) @map("sync_status")
  spentAt     DateTime          @map("spent_at")
  startDate   DateTime?         @map("start_date")
  endDate     DateTime?         @map("end_date")
  nextDueDate DateTime?         @map("next_due_date")
  createdAt   DateTime          @default(now()) @map("created_at")

  trader      Trader            @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([traderId])
  @@index([traderId, spentAt])
  @@index([traderId, category])
  @@index([traderId, expenseType])
  @@index([traderId, frequency])
  @@map("expenses")
}

model StockItem {
  id                String     @id @default(uuid())
  traderId          String     @map("trader_id")
  itemName          String     @map("item_name")
  quantity          Int        @default(0)
  unitPrice         Decimal    @db.Decimal(12, 2) @map("unit_price")
  costPrice         Decimal    @db.Decimal(12, 2) @map("cost_price")
  lowStockThreshold Int        @default(5) @map("low_stock_threshold")
  syncStatus        SyncStatus @default(PENDING) @map("sync_status")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  createdAt         DateTime   @default(now()) @map("created_at")

  trader            Trader     @relation(fields: [traderId], references: [id], onDelete: Cascade)
  sales             Sale[]

  @@unique([traderId, itemName])
  @@index([traderId])
  @@map("stock_items")
}

model Debtor {
  id           String     @id @default(uuid())
  traderId     String     @map("trader_id")
  customerName String     @map("customer_name")
  phoneNumber  String?    @map("phone_number")
  totalOwed    Decimal    @db.Decimal(12, 2) @map("total_owed")
  totalPaid    Decimal    @db.Decimal(12, 2) @default(0) @map("total_paid")
  status       DebtStatus @default(ACTIVE)
  dueDate      DateTime?  @map("due_date")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  trader       Trader     @relation(fields: [traderId], references: [id], onDelete: Cascade)
  sales        Sale[]
  payments     Payment[]

  @@index([traderId])
  @@index([traderId, status])
  @@map("debtors")
}

model Payment {
  id        String   @id @default(uuid())
  debtorId  String   @map("debtor_id")
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @map("paid_at")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  debtor    Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)

  @@index([debtorId])
  @@map("payments")
}