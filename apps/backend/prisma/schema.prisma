// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PaymentType {
  CASH
  TRANSFER
  DEBT
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum DebtStatus {
  ACTIVE
  PARTIAL
  CLEARED
}

enum Language {
  EN
  PIDGIN
  IGBO
  YORUBA
  HAUSA
}

enum TraderRole {
  OWNER
  SALESPERSON
}

enum InternalRole {
  PLATFORM_ADMIN
  PLATFORM_DEV
}

enum ExpenseCategory {
  RESTOCK
  TRANSPORT
  MARKET_FEES
  PACKAGING
  EQUIPMENT
  FOOD
  RENT
  ELECTRICITY
  WATER
  SALARY
  LEVY
  REPAIRS
  UTILITIES
  OTHER
}

enum ExpenseType {
  ONE_TIME
  RECURRING
}

enum ExpenseFrequency {
  DAILY
  MONTHLY
  YEARLY
}

enum SavingsTargetPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

enum StockMovementType {
  INITIAL
  RESTOCK
  SALE
  DAMAGE
  CORRECTION
}

enum SavingsVerificationAttemptStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
}

model Trader {
  id             String      @id @default(uuid())
  phoneNumber    String      @unique @map("phone_number")
  name           String
  pinHash        String      @map("pin_hash")
  language       Language    @default(EN)
  businessName   String?     @map("business_name")
  savingsTargetAmount Decimal? @db.Decimal(12, 2) @map("savings_target_amount")
  savingsTargetPeriod SavingsTargetPeriod? @map("savings_target_period")
  savingsTargetUpdatedAt DateTime? @map("savings_target_updated_at")
  savingsBankName String? @map("savings_bank_name")
  savingsBankCode String? @map("savings_bank_code")
  savingsAccountNumber String? @map("savings_account_number")
  savingsAccountName String? @map("savings_account_name")
  savingsAccountSetupAt DateTime? @map("savings_account_setup_at")
  role           TraderRole  @default(OWNER)
  isActive       Boolean     @default(true) @map("is_active")
  ownerTraderId  String?     @map("owner_trader_id")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  owner          Trader?     @relation("OwnerSalespeople", fields: [ownerTraderId], references: [id], onDelete: SetNull)
  salespeople    Trader[]    @relation("OwnerSalespeople")
  sales          Sale[]
  expenses       Expense[]
  stockItems     StockItem[]
  stockMovements StockMovement[]
  debtors        Debtor[]
  savingsEntries SavingsEntry[] @relation("BusinessSavings")
  recordedSavings SavingsEntry[] @relation("RecordedSavings")
  dayClosures     DayClose[]
  customers      Customer[]
  suppliers      Supplier[]
  savingsVerificationAttempts SavingsVerificationAttempt[]
  paystackWebhookEvents     PaystackWebhookEvent[]
  paystackTransferRecipient PaystackTransferRecipient?

  @@index([phoneNumber])
  @@index([ownerTraderId])
  @@map("traders")
}

model InternalUser {
  id           String       @id @default(uuid())
  phoneNumber  String       @unique @map("phone_number")
  fullName     String       @map("full_name")
  passwordHash String       @map("password_hash")
  role         InternalRole
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@index([role])
  @@index([isActive])
  @@map("internal_users")
}

model Customer {
  id         String   @id @default(uuid())
  traderId   String   @map("trader_id")
  name       String
  phoneNumber String? @map("phone_number")
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  trader     Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([traderId, createdAt])
  @@map("customers")
}

model Supplier {
  id          String   @id @default(uuid())
  traderId    String   @map("trader_id")
  name        String
  phoneNumber String?  @map("phone_number")
  itemCategory String? @map("item_category")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  trader      Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([traderId, createdAt])
  @@map("suppliers")
}

model SavingsEntry {
  id                String   @id @default(uuid())
  traderId          String   @map("trader_id")
  createdByTraderId String   @map("created_by_trader_id")
  amount            Decimal  @db.Decimal(12, 2)
  note              String?
  status            String   @default("DECLARED")
  reconciledAt      DateTime? @map("reconciled_at")
  verifiedAt        DateTime? @map("verified_at")
  verificationReference String? @map("verification_reference")
  verificationTransferId String? @map("verification_transfer_id")
  verificationLastStatus String? @map("verification_last_status")
  payoutRecipientCode String? @map("payout_recipient_code")
  payoutReference String? @map("payout_reference")
  payoutTransferId String? @map("payout_transfer_id")
  payoutStatus String? @map("payout_status")
  payoutFailureReason String? @map("payout_failure_reason")
  payoutTransferredAt DateTime? @map("payout_transferred_at")
  savedAt           DateTime @map("saved_at")
  createdAt         DateTime @default(now()) @map("created_at")

  trader            Trader   @relation("BusinessSavings", fields: [traderId], references: [id], onDelete: Cascade)
  createdBy         Trader   @relation("RecordedSavings", fields: [createdByTraderId], references: [id], onDelete: Cascade)
  verificationAttempts SavingsVerificationAttempt[]

  @@index([traderId, savedAt])
  @@index([traderId, createdAt])
  @@map("savings_entries")
}

model SavingsVerificationAttempt {
  id                    String   @id @default(uuid())
  savingsEntryId        String   @map("savings_entry_id")
  traderId              String   @map("trader_id")
  reference             String   @unique
  expectedAmount        Decimal  @db.Decimal(12, 2) @map("expected_amount")
  status                SavingsVerificationAttemptStatus @default(PENDING)
  authorizationUrl      String   @map("authorization_url")
  accessCode            String?  @map("access_code")
  paystackEmail         String   @map("paystack_email")
  paystackTransactionId String?  @map("paystack_transaction_id")
  paystackReference     String?  @map("paystack_reference")
  expiresAt             DateTime? @map("expires_at")
  verifiedAt            DateTime? @map("verified_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  savingsEntry          SavingsEntry @relation(fields: [savingsEntryId], references: [id], onDelete: Cascade)
  trader                Trader       @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([traderId, status, createdAt])
  @@index([savingsEntryId, createdAt])
  @@map("savings_verification_attempts")
}

model PaystackTransferRecipient {
  id            String   @id @default(uuid())
  traderId      String   @unique @map("trader_id")
  recipientCode String   @unique @map("recipient_code")
  accountNumber String   @map("account_number")
  bankCode      String   @map("bank_code")
  accountName   String   @map("account_name")
  bankName      String   @map("bank_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  trader        Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([recipientCode])
  @@map("paystack_transfer_recipients")
}

model PaystackWebhookEvent {
  id                  String   @id @default(uuid())
  traderId            String?  @map("trader_id")
  eventType           String   @map("event_type")
  externalReference   String?  @map("external_reference")
  signature           String?  @map("signature")
  payload             Json
  processedAt         DateTime? @map("processed_at")
  createdAt           DateTime @default(now()) @map("created_at")

  trader              Trader?  @relation(fields: [traderId], references: [id], onDelete: SetNull)

  @@index([traderId, createdAt])
  @@index([eventType, createdAt])
  @@map("paystack_webhook_events")
}

model DayClose {
  id                         String   @id @default(uuid())
  traderId                   String   @map("trader_id")
  dayKey                     String   @map("day_key")
  fromAt                     DateTime @map("from_at")
  toAt                       DateTime @map("to_at")
  salesTotal                 Decimal  @db.Decimal(12, 2) @map("sales_total")
  salesCount                 Int      @default(0) @map("sales_count")
  cashSalesTotal             Decimal  @db.Decimal(12, 2) @map("cash_sales_total")
  transferSalesTotal         Decimal  @db.Decimal(12, 2) @map("transfer_sales_total")
  debtSalesTotal             Decimal  @db.Decimal(12, 2) @map("debt_sales_total")
  expensesTotal              Decimal  @db.Decimal(12, 2) @map("expenses_total")
  expensesCount              Int      @default(0) @map("expenses_count")
  collectionsTotal           Decimal  @db.Decimal(12, 2) @map("collections_total")
  collectionsCount           Int      @default(0) @map("collections_count")
  savingsTotal               Decimal  @db.Decimal(12, 2) @map("savings_total")
  savingsCount               Int      @default(0) @map("savings_count")
  reconciledSavingsCount     Int      @default(0) @map("reconciled_savings_count")
  verifiedSavingsCount       Int      @default(0) @map("verified_savings_count")
  operatingBalance           Decimal  @db.Decimal(12, 2) @map("operating_balance")
  eligibleSalesAfterExpenses Decimal  @db.Decimal(12, 2) @map("eligible_sales_after_expenses")
  stillAvailableToSave       Decimal  @db.Decimal(12, 2) @map("still_available_to_save")
  note                       String?
  closedByTraderId           String   @map("closed_by_trader_id")
  closedByTraderName         String?  @map("closed_by_trader_name")
  closedAt                   DateTime @default(now()) @map("closed_at")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  trader                     Trader   @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@unique([traderId, dayKey])
  @@index([traderId, closedAt])
  @@map("day_closures")
}

model Sale {
  id          String      @id @default(uuid())
  traderId    String      @map("trader_id")
  debtorId    String?     @map("debtor_id")
  stockItemId String?     @map("stock_item_id")
  itemName    String      @map("item_name")
  quantity    Int         @default(1)
  unitPrice   Decimal     @db.Decimal(12, 2) @map("unit_price")
  amount      Decimal     @db.Decimal(12, 2)
  recordedByTraderId String? @map("recorded_by_trader_id")
  recordedByName String? @map("recorded_by_name")
  paymentType PaymentType @map("payment_type")
  syncStatus  SyncStatus  @default(PENDING) @map("sync_status")
  soldAt      DateTime    @map("sold_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  trader      Trader      @relation(fields: [traderId], references: [id], onDelete: Cascade)
  debtor      Debtor?     @relation(fields: [debtorId], references: [id])
  stockItem   StockItem?  @relation(fields: [stockItemId], references: [id])

  @@index([traderId])
  @@index([soldAt])
  @@index([stockItemId])
  @@index([traderId, soldAt])
  @@map("sales")
}

model Expense {
  id          String            @id @default(uuid())
  traderId    String            @map("trader_id")
  description String
  amount      Decimal           @db.Decimal(12, 2)
  category    ExpenseCategory
  expenseType ExpenseType       @default(ONE_TIME) @map("expense_type")
  frequency   ExpenseFrequency?
  note        String?
  recordedByTraderId String?    @map("recorded_by_trader_id")
  recordedByName String?        @map("recorded_by_name")
  syncStatus  SyncStatus        @default(PENDING) @map("sync_status")
  spentAt     DateTime          @map("spent_at")
  startDate   DateTime?         @map("start_date")
  endDate     DateTime?         @map("end_date")
  nextDueDate DateTime?         @map("next_due_date")
  createdAt   DateTime          @default(now()) @map("created_at")

  trader      Trader            @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([traderId])
  @@index([traderId, spentAt])
  @@index([traderId, category])
  @@index([traderId, expenseType])
  @@index([traderId, frequency])
  @@map("expenses")
}

model StockItem {
  id                String     @id @default(uuid())
  traderId          String     @map("trader_id")
  itemName          String     @map("item_name")
  quantity          Int        @default(0)
  unitName          String     @default("piece") @map("unit_name")
  unitPrice         Decimal    @db.Decimal(12, 2) @map("unit_price")
  costPrice         Decimal    @db.Decimal(12, 2) @map("cost_price")
  wholesalePrice    Decimal?   @db.Decimal(12, 2) @map("wholesale_price")
  wholesaleMinQty   Int?       @map("wholesale_min_qty")
  lowStockThreshold Int        @default(5) @map("low_stock_threshold")
  syncStatus        SyncStatus @default(PENDING) @map("sync_status")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  createdAt         DateTime   @default(now()) @map("created_at")

  trader            Trader     @relation(fields: [traderId], references: [id], onDelete: Cascade)
  sales             Sale[]
  movements         StockMovement[]

  @@unique([traderId, itemName])
  @@index([traderId])
  @@map("stock_items")
}

model StockMovement {
  id              String            @id @default(uuid())
  traderId        String            @map("trader_id")
  stockItemId     String            @map("stock_item_id")
  type            StockMovementType
  quantityDelta   Int               @map("quantity_delta")
  quantityAfter   Int?              @map("quantity_after")
  unitName        String            @default("piece") @map("unit_name")
  actorTraderId   String?           @map("actor_trader_id")
  actorTraderName String?           @map("actor_trader_name")
  unitPrice       Decimal?          @db.Decimal(12, 2) @map("unit_price")
  costPrice       Decimal?          @db.Decimal(12, 2) @map("cost_price")
  wholesalePrice  Decimal?          @db.Decimal(12, 2) @map("wholesale_price")
  wholesaleMinQty Int?              @map("wholesale_min_qty")
  note            String?
  referenceId     String?           @map("reference_id")
  happenedAt      DateTime          @map("happened_at")
  createdAt       DateTime          @default(now()) @map("created_at")

  trader          Trader            @relation(fields: [traderId], references: [id], onDelete: Cascade)
  stockItem       StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([traderId, stockItemId, happenedAt])
  @@index([traderId, happenedAt])
  @@map("stock_movements")
}

model Debtor {
  id           String     @id @default(uuid())
  traderId     String     @map("trader_id")
  customerName String     @map("customer_name")
  phoneNumber  String?    @map("phone_number")
  totalOwed    Decimal    @db.Decimal(12, 2) @map("total_owed")
  totalPaid    Decimal    @db.Decimal(12, 2) @default(0) @map("total_paid")
  status       DebtStatus @default(ACTIVE)
  dueDate      DateTime?  @map("due_date")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  trader       Trader     @relation(fields: [traderId], references: [id], onDelete: Cascade)
  sales        Sale[]
  payments     Payment[]

  @@index([traderId])
  @@index([traderId, status])
  @@map("debtors")
}

model Payment {
  id        String   @id @default(uuid())
  debtorId  String   @map("debtor_id")
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @map("paid_at")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  debtor    Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)

  @@index([debtorId])
  @@map("payments")
}
