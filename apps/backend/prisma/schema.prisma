// prisma/schema.prisma

// This tells Prisma which database we're using and where to find it.
// The DATABASE_URL comes from .env — never hardcoded.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---
// We use enums instead of plain strings for fixed-value fields.
// Reason: the database enforces valid values — you can't accidentally
// insert "csh" instead of "CASH". Catches bugs at the data layer.

enum PaymentType {
  CASH
  TRANSFER
  DEBT
}

enum SyncStatus {
  PENDING   // written offline, not yet synced to server
  SYNCED    // confirmed on server
  FAILED    // sync attempted but failed
}

enum DebtStatus {
  ACTIVE    // still owes money
  PARTIAL   // some payments made
  CLEARED   // fully paid
}

enum Language {
  EN
  PIDGIN
  IGBO
  YORUBA
  HAUSA
}

// --- Trader ---
// The core user of the system. One trader = one business.
// We use phone_number as the login identifier — not email.
// Market traders think in phone numbers, not email addresses.

model Trader {
  id           String    @id @default(uuid())
  phoneNumber  String    @unique @map("phone_number")
  name         String
  pinHash      String    @map("pin_hash")  // NEVER store plain PINs
  language     Language  @default(EN)
  businessName String?   @map("business_name") // optional
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  sales        Sale[]
  expenses     Expense[]
  stockItems   StockItem[]
  debtors      Debtor[]

  // Indexes
  // We index phoneNumber because every login query filters by it.
  // Without this index, Postgres scans the entire table on every login.
  // With 10,000 traders that's fine. With 1,000,000 it's a disaster.
  @@index([phoneNumber])
  @@map("traders")  // snake_case table names in DB, camelCase in code
}

// --- Sale ---
// Every transaction a trader makes. This will be the highest-volume table.
// A busy trader might record 50-100 sales per day.

model Sale {
  id          String      @id @default(uuid())
  traderId    String      @map("trader_id")
  debtorId    String?     @map("debtor_id") // null if cash/transfer sale
  itemName    String      @map("item_name")
  amount      Decimal     @db.Decimal(12, 2) // 12 digits, 2 decimal places
  paymentType PaymentType @map("payment_type")
  syncStatus  SyncStatus  @default(PENDING) @map("sync_status")
  soldAt      DateTime    @map("sold_at")   // when the sale actually happened
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  trader      Trader      @relation(fields: [traderId], references: [id], onDelete: Cascade)
  debtor      Debtor?     @relation(fields: [debtorId], references: [id])

  // Why these indexes?
  // traderId: every query filters by trader — "show MY sales"
  // soldAt: traders filter by date — "show sales THIS WEEK"
  // Compound index (traderId + soldAt): the most common query pattern
  // is "this trader's sales between date A and date B" — one index
  // serves both filters simultaneously, much faster than two separate ones.
  @@index([traderId])
  @@index([soldAt])
  @@index([traderId, soldAt])
  @@map("sales")
}

// --- Expense ---
// Money going OUT of the business. Same high-volume table as sales.

model Expense {
  id          String     @id @default(uuid())
  traderId    String     @map("trader_id")
  description String
  amount      Decimal    @db.Decimal(12, 2)
  category    String     // "transport", "restock", "market fees" etc.
  syncStatus  SyncStatus @default(PENDING) @map("sync_status")
  spentAt     DateTime   @map("spent_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  trader      Trader     @relation(fields: [traderId], references: [id], onDelete: Cascade)

  @@index([traderId])
  @@index([traderId, spentAt])
  @@map("expenses")
}

// --- StockItem ---
// Inventory. Each item the trader sells.

model StockItem {
  id                String     @id @default(uuid())
  traderId          String     @map("trader_id")
  itemName          String     @map("item_name")
  quantity          Int        @default(0)
  unitPrice         Decimal    @db.Decimal(12, 2) @map("unit_price")
  lowStockThreshold Int        @default(5) @map("low_stock_threshold")
  syncStatus        SyncStatus @default(PENDING) @map("sync_status")
  updatedAt         DateTime   @updatedAt @map("updated_at")
  createdAt         DateTime   @default(now()) @map("created_at")

  trader            Trader     @relation(fields: [traderId], references: [id], onDelete: Cascade)

  // Unique constraint: one trader can't have two stock items
  // with the same name — prevents accidental duplicates
  @@unique([traderId, itemName])
  @@index([traderId])
  @@map("stock_items")
}

// --- Debtor ---
// Customers who owe money. Separate from Sale so we can track
// multiple sales to the same debtor and partial payments over time.

model Debtor {
  id           String     @id @default(uuid())
  traderId     String     @map("trader_id")
  customerName String     @map("customer_name")
  phoneNumber  String?    @map("phone_number") // for SMS reminders later
  totalOwed    Decimal    @db.Decimal(12, 2) @map("total_owed")
  totalPaid    Decimal    @db.Decimal(12, 2) @default(0) @map("total_paid")
  status       DebtStatus @default(ACTIVE)
  dueDate      DateTime?  @map("due_date")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  trader       Trader     @relation(fields: [traderId], references: [id], onDelete: Cascade)
  sales        Sale[]
  payments     Payment[]

  @@index([traderId])
  @@index([traderId, status]) // "show all ACTIVE debtors for this trader"
  @@map("debtors")
}

// --- Payment ---
// Individual payments against a debt. Gives full payment history.
// A debtor might pay ₦5,000 of a ₦20,000 debt — that's one Payment record.

model Payment {
  id        String   @id @default(uuid())
  debtorId  String   @map("debtor_id")
  amount    Decimal  @db.Decimal(12, 2)
  paidAt    DateTime @map("paid_at")
  note      String?  // "paid via transfer", "partial - market day" etc.
  createdAt DateTime @default(now()) @map("created_at")

  debtor    Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)

  @@index([debtorId])
  @@map("payments")
}
